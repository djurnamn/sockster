# Port for the socket server to listen on
SOCKSTER_PORT=4000

# Allowed CORS origin(s) for connecting clients.
# Accepts a single origin, a comma-separated list, or * to allow any origin.
# For local development with e.g. Next.js this is typically http://localhost:3000
SOCKSTER_ORIGIN_URL=http://localhost:3000

# Whether events are echoed back to the client that sent them.
# Set to false to only relay events to the other connected clients.
SOCKSTER_ECHO=true
